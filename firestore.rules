rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own user document
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;

      // Chat history - users can only read/write their own chat messages
      match /chats/{chatId} {
        allow read, write: if request.auth.uid == userId;
      }
    }

    // Exercises are readable by everyone, writable by no one (admin only)
    match /exercises/{exerciseId} {
      allow read: if request.auth != null;
      allow create, update, delete: if false; // Admin only
    }

    // Workouts - users can only read/write their own
    match /workouts/{workoutId} {
      allow read, write: if request.auth.uid == resource.data.userId;
      allow create: if request.auth.uid == request.resource.data.userId;
    }

    // Sessions - users can only read/write their own
    match /sessions/{sessionId} {
      allow read, write: if request.auth.uid == resource.data.userId;
      allow create: if request.auth.uid == request.resource.data.userId;
    }

    // Default: deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
